# Configuração do Replit — Conatus Institute
# O código da aplicação fica em ./conatus-academy-react (React + Express).
# Os scripts do package.json na raiz orquestram o build e a execução.

# Banco é externo (Supabase), então NÃO usamos o módulo postgresql do Replit.
# Com ele presente, PGHOST existe e o fallback do server/db/connection.js
# conectaria silenciosamente num banco vazio se um secret DB_* faltasse.
modules = ["nodejs-20", "web"]

# Botão "Run": compila o frontend e sobe o servidor Express (API + site) numa
# única porta. É intencional recompilar aqui para o dist/ existir na primeira vez.
run = "npm run build && npm start"
 
hidden = [".config", "dist", "node_modules"]
 
[agent]
expertMode = true
 
[nix]
channel = "stable-25_05"
 
[env]
NODE_ENV = "production"
 
# Deploy (Reserved VM / Autoscale): build separado do run para não recompilar
# a cada requisição.
[deployment]
deploymentTarget = "autoscale"
build = ["sh", "-c", "npm run build"]
run = ["sh", "-c", "npm start"]
 
[userenv]
 
[userenv.production]
APP_URL = "https://conatus-institute.replit.app"
CORS_ORIGIN = "https://conatus-institute.replit.app"
DB_HOST = "aws-1-sa-east-1.pooler.supabase.com"
DB_NAME = "postgres"
DB_PORT = "5432"
DB_SSL = "true"
DB_SSL_CA = "./supabase-ca.crt"
DB_USER = "postgres.zatmhjfpjutimscfxtny"
# MAIL_FROM é a caixa de envio no path do Graph (POST /users/{MAIL_FROM}/sendMail):
# precisa ser um mailbox do tenant. Um endereço @gmail.com aqui derruba todo envio.
MAIL_FROM = "suporte.ti@conatusprocedures.com"
NODE_ENV = "production"
OPENROUTER_MODEL = "nvidia/nemotron-3-super-120b-a12b:free,openai/gpt-oss-120b:free,meta-llama/llama-3.3-70b-instruct:free,qwen/qwen3-next-80b-a3b-instruct:free"
ELEVENLABS_VOICE_ID = "HXmVs82qUTKZy5PrSBjo"
TTS_PROVIDER = "elevenlabs"
MICROSOFT_CLIENT_ID = "ad519dd0-d255-49f5-9f8b-ca4b42da9838"
MICROSOFT_TENANT_ID = "0e7ad7e0-24f5-4023-9800-522ac611b913"

[userenv.development]
OPENROUTER_MODEL = "nvidia/nemotron-3-super-120b-a12b:free,openai/gpt-oss-120b:free,meta-llama/llama-3.3-70b-instruct:free,qwen/qwen3-next-80b-a3b-instruct:free"
ELEVENLABS_VOICE_ID = "HXmVs82qUTKZy5PrSBjo"
TTS_PROVIDER = "elevenlabs"
PORT = "5000"
MAIL_FROM = "suporte.ti@conatusprocedures.com"
MICROSOFT_CLIENT_ID = "ad519dd0-d255-49f5-9f8b-ca4b42da9838"
MICROSOFT_TENANT_ID = "0e7ad7e0-24f5-4023-9800-522ac611b913"
APP_URL = "https://conatus-institute-deploy--edgardhenriqu.replit.app"
CORS_ORIGIN = "https://conatus-institute-deploy--edgardhenriqu.replit.app"
DB_HOST = "aws-1-sa-east-1.pooler.supabase.com"
DB_NAME = "postgres"
DB_PORT = "5432"
DB_SSL = "true"
DB_SSL_CA = "./supabase-ca.crt"
