# ATENÇÃO: o workspace de desenvolvimento aponta para o MESMO banco Supabase de
# produção (não há instância separada) — cuidado ao testar escrita por aqui.
NODE_ENV = "development"

[userenv.shared]

[[ports]]
localPort = 3000
externalPort = 80
 
[[ports]]
localPort = 5000
externalPort = 5000

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run build && npm start"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"
