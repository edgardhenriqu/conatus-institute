# ── Banco de dados ────────────────────────────────────────────────────────────
# Desenvolvimento local: use localhost (ou o host da sua instância PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=conatus_db
DB_USER=conatus_user
DB_PASSWORD=sua_senha_aqui

# ── Supabase (produção) ───────────────────────────────────────────────────────
# Use o "Session Pooler" em Project Settings → Database. Exemplo:
#   DB_HOST=aws-0-sa-east-1.pooler.supabase.com
#   DB_PORT=5432
#   DB_NAME=postgres
#   DB_USER=postgres.<seu-project-ref>
#   DB_PASSWORD=<senha-do-banco>
# SSL é obrigatório no Supabase:
#   DB_SSL=true
# Verificação do certificado (recomendado): baixe o CA em
# Project Settings → Database → SSL Configuration e aponte para o arquivo:
#   DB_SSL_CA=./supabase-ca.crt
# Sem o CA, apenas em ambiente de confiança, para pular a verificação (inseguro):
#   DB_SSL_NO_VERIFY=true
DB_SSL=false

# ── Autenticação JWT ──────────────────────────────────────────────────────────
JWT_SECRET=substitua_por_uma_chave_secreta_longa_com_pelo_menos_32_chars

# ── Servidor Express ──────────────────────────────────────────────────────────
# No Replit a porta é injetada automaticamente em process.env.PORT — NÃO fixe.
# Localmente, 3000 é o padrão.
PORT=3000

# Ambiente: "production" no Replit, "development" localmente.
NODE_ENV=development

# ── CORS ─────────────────────────────────────────────────────────────────────
# No Replit o frontend e a API rodam na MESMA origem, então o CORS é opcional.
# Deixe VAZIO para refletir a origem da requisição, ou informe as origens
# permitidas separadas por vírgula.
# Desenvolvimento: http://localhost:5173
CORS_ORIGIN=http://localhost:5173

# ── Confirmação de e-mail ─────────────────────────────────────────────────────
# URL PÚBLICA do site, usada para montar os links de confirmação de e-mail e
# redefinição de senha.
# No Replit, use a URL do seu Repl/deploy, ex.:
#   APP_URL=https://conatus-institute.SEU-USUARIO.repl.co
APP_URL=http://localhost:5173

# Envio de e-mail de confirmação (SMTP). Para Gmail, use uma "Senha de app".
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here
MAIL_FROM=your_email@gmail.com

# ── Tutor virtual (assistente RAG dos cursos) ─────────────────────────────────
# Duas metades, dois provedores:
#
# 1) EMBEDDINGS — sempre Gemini (gemini-embedding-001, 768 dims). Não troque de
#    provedor sem migrar: os vetores em aula_chunks são vector(768) e vetores de
#    modelos diferentes não são comparáveis (exigiria reindexar tudo com
#    server/db/backfillEmbeddings.js). Chave em aistudio.google.com/apikey
GEMINI_API_KEY=sua_chave_do_google_ai_studio

# 2) GERAÇÃO DA RESPOSTA — OpenRouter (API no formato OpenAI). Evita a quota
#    gratuita do Gemini, que estoura (429) e deixa o tutor mudo.
#    Chave em openrouter.ai/keys. Sem ela, a geração cai de volta no Gemini.
OPENROUTER_API_KEY=sk-or-v1-sua_chave_do_openrouter

# Modelo(s) que respondem ao aluno. Catálogo: openrouter.ai/models
# Aceita uma lista separada por vírgula: se o primeiro falhar (sem quota, fora
# do ar), o tutor cai no próximo. Modelos com sufixo ":free" não consomem
# créditos, mas têm limite diário de requisições na conta.
# Padrão se omitido: a cascata gratuita definida em src/services/ragChat.js
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# ── Voz da narração das aulas ─────────────────────────────────────────────────
# Os blocos marcados com o megafone viram roteiro (LLM acima) e o roteiro vira
# ÁUDIO (MP3). O áudio é gerado uma vez, ao salvar a aula, e guardado no banco —
# não é sintetizado a cada play.
#
# SEM PROVEDOR CONFIGURADO a narração continua funcionando: o player fala o
# roteiro com a voz do navegador do aluno (pior, mas nunca deixa a aula sem
# narração).
#
# elevenlabs (padrão) — voz melhor e vozes pt-BR nativas; exige assinatura paga.
# gemini              — grátis, reusa a GEMINI_API_KEY acima, MAS o free tier só
#                       permite 10 sínteses POR DIA (ver adiante).
TTS_PROVIDER=elevenlabs

# ── Provedor: elevenlabs ──
# Chave em elevenlabs.io → API Keys. Exige plano pago: no gratuito a API recusa
# vozes da Voice Library (402) e a cota de 10 mil caracteres/mês não cobre nem a
# carga inicial de um curso (o de Data Centers sozinho consome ~16 mil).
ELEVENLABS_API_KEY=sua_chave_do_elevenlabs

# Voz que narra — obrigatória para este provedor. Para listar as da sua conta:
#   cd server && node scripts/vozesElevenlabs.js
# (a chave precisa da permissão voices_read). Prefira uma voz treinada em pt-BR:
# uma voz inglesa lendo português sai com sotaque.
ELEVENLABS_VOICE_ID=
# ELEVENLABS_MODEL=eleven_multilingual_v2
# ELEVENLABS_FORMAT=mp3_44100_64

# ── Provedor: gemini ──
# Só é lido quando TTS_PROVIDER=gemini. Modelo gratuito de TTS do Google, com a
# mesma voz do assistente Jarvis. 30 vozes prontas: Zephyr, Puck, Charon, Kore…
# Catálogo e amostras: ai.google.dev/gemini-api/docs/speech-generation
#
# CUIDADO COM A COTA: no free tier são 10 SÍNTESES POR DIA (por projeto), não 10
# por minuto — medido em 2026-07-14, quotaId GenerateRequestsPerDayPerProject
# PerModel-FreeTier. Um curso com 42 trechos levaria ~5 dias para ganhar voz, e
# cada edição de aula disputa a mesma cota. Ativar o faturamento no projeto do
# Google AI remove o limite e sai por centavos (US$ 10 por 1M de tokens de áudio).
# GEMINI_TTS_VOICE=Charon
#
# O modelo é PREVIEW e pode ser aposentado pelo Google. Se a síntese começar a
# falhar com 404, troque o ID aqui.
# GEMINI_TTS_MODEL=gemini-2.5-flash-preview-tts

# Depois de configurar (ou de trocar a voz/provedor), gere o áudio das aulas que
# já têm roteiro — sem isso, só as aulas salvas de novo ganham a voz nova:
#   cd server && node scripts/gerarAudioNarracoes.js --dry        # o que falta
#   cd server && node scripts/gerarAudioNarracoes.js --aula 131    # só uma aula
#   cd server && node scripts/gerarAudioNarracoes.js               # tudo
